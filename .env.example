# Copy this file to .env and fill in your Supabase project values.
# The anon key is public by design (safe to ship in the extension bundle).
# Data is protected by insert-only row-level security, not by hiding the key.
# In CI, set these as environment variables instead of committing a .env file.
# Dev vs prod: point local .env at a DEV Supabase project so test builds never
# write into production telemetry. The release workflow injects the PROD creds.
SUPABASE_URL=
SUPABASE_ANON_KEY=
